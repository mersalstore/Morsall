# انسخ الملف ده وسمّيه .env في نفس مجلد package.json بعد ما تعبّي القيم.
# على السيرفر: ما ترفعهوش في مجلد يتعرَّض على الويب (خليّه جوّه مجلد التطبيق الخاص بالـ Node بس).

# --- Postgres (إلزامي) ---
# رابط واحد على الأقل؛ غالبًا DATABASE_URL كفاية
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# اختياري (Neon / Pooling): لو عندك رابط pooled منفصل
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=

# --- NextAuth (إلزامي على السيرفر) ---
NEXTAUTH_URL=https://morsall.com
NEXTAUTH_SECRET=ضع_نصًا_طويلًا_عشوائيًا_مثلاً_64_حرف

# --- Google OAuth (لو مش مستخدم خليه فاضي أو احذف السطرين) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Upload (اختياري لكن مُستحسن) ---
# مسار حفظ صور المنتجات بالنسبة لمجلد المشروع أو مسار مطلق.
UPLOAD_DIR=public/uploads
# أقصى حجم للصورة بالميجابايت.
MAX_UPLOAD_SIZE_MB=10
# مهلة التحويل للبروكسي بالمللي ثانية.
UPLOAD_PROXY_TIMEOUT_MS=20000
# مسارات التحويل (بالترتيب). افصل بين كل هدف بفاصلة.
HOSTINGER_UPLOAD_TARGETS=http://82.198.228.182/api/upload,https://morsall.com/api/upload
# بروكسي الرفع (لو في نشر مختلط Vercel -> Hostinger)
HOSTINGER_UPLOAD_HOST=82.198.228.182
INTERNAL_UPLOAD_PROXY_SECRET=غيّر_القيمة_دي_بسلسلة_سرية_طويلة
# وضع نجاة مؤقت: حفظ الصورة كـ data URL لو فشل التحويل.
UPLOAD_INLINE_FALLBACK=1
MAX_INLINE_UPLOAD_SIZE_MB=2

# ثابتة لـ Hostinger مع Prisma
PRISMA_CLIENT_ENGINE_TYPE=binary
NODE_ENV=production
