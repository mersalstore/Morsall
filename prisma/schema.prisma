generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "linux-musl"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  role          String    @default("CUSTOMER")
  age           Int?
  interests     String?
  isOnboarded   Boolean   @default(false)
  lastIp        String?
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  orders        Order[]
  reviews       Review[]
  sessions      Session[]
  vendorProfile Vendor?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vendor {
  id                 String            @id @default(cuid())
  userId             String            @unique
  storeName          String
  storeDescription   String?
  bankStatementUrl   String?
  commercialRegUrl   String?
  status             String            @default("PENDING")
  commissionType     String            @default("PERCENTAGE")
  commissionRate     Float             @default(10.0)
  fixedFee           Float             @default(0.0)
  subscriptionFee    Float             @default(0.0)
  location           String?
  shippingModel      String            @default("VENDOR_PACKS")
  phone              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  isTrialUsed        Boolean           @default(false)
  planId             String?
  slug               String?           @unique
  subscriptionEndsAt DateTime?
  address            String?
  facebookUrl        String?
  instagramUrl       String?
  primaryColor       String            @default("#0F1629")
  secondaryColor     String            @default("#3B82F6")
  storeBanner        String?
  storeLogo          String?
  whatsappNumber     String?
  coupons            Coupon[]
  orderItems         OrderItem[]
  products           Product[]
  plan               SubscriptionPlan? @relation(fields: [planId], references: [id])
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals        Withdrawal[]
}

model SubscriptionPlan {
  id           String   @id @default(cuid())
  name         String
  price        Float
  durationDays Int
  isTrial      Boolean  @default(false)
  createdAt    DateTime @default(now())
  vendors      Vendor[]
}

model Product {
  id               String             @id @default(cuid())
  title            String
  description      String
  price            Float
  stock            Int                @default(0)
  images           String?
  sizes            String?
  colors           String?
  status           String             @default("PENDING")
  vendorId         String
  categoryId       String?
  purchaseCount    Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  brand            String?
  bundleData       String?
  height           Float?
  length           Float?
  ram              String?
  range            String?
  screenSize       String?
  shortDescription String?
  sku              String?
  storage          String?
  type             String             @default("SIMPLE")
  weight           Float?
  width            Float?
  discountPrice    Float?
  discountType     String?
  orderItems       OrderItem[]
  category         Category?          @relation(fields: [categoryId], references: [id])
  vendor           Vendor             @relation(fields: [vendorId], references: [id])
  attributes       ProductAttribute[]
  variations       ProductVariation[]
  reviews          Review[]
}

model ProductAttribute {
  id        String   @id @default(cuid())
  productId String
  name      String
  values    String[]
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariation {
  id          String      @id @default(cuid())
  productId   String
  sku         String?
  price       Float?
  stock       Int         @default(0)
  combination String
  image       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Attribute {
  id        String            @id @default(cuid())
  name      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  options   AttributeOption[]
}

model AttributeOption {
  id          String    @id @default(cuid())
  attributeId String
  value       String
  createdAt   DateTime  @default(now())
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  icon     String?
  products Product[]
}

model Order {
  id                String          @id @default(cuid())
  customerId        String
  status            String          @default("PENDING_APPROVAL")
  totalAmount       Float
  shippingCost      Float           @default(0)
  paymentMethod     String
  city              String
  district          String
  street            String
  phone             String
  customerEmail     String?
  customerName      String?
  notes             String?
  paymentScreenshot String?
  paymentVerified   Boolean         @default(false)
  paymentNote       String?
  trackingLat       Float?
  trackingLng       Float?
  trackingNumber    String?
  trackingUrl       String?
  estimatedDays     Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  driverId          String?
  customer          User            @relation(fields: [customerId], references: [id])
  driver            DeliveryDriver? @relation(fields: [driverId], references: [id])
  items             OrderItem[]
}

model OrderItem {
  id          String            @id @default(cuid())
  orderId     String
  productId   String
  vendorId    String
  quantity    Int
  priceAtTime Float
  size        String?
  color       String?
  variationId String?
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product           @relation(fields: [productId], references: [id])
  variation   ProductVariation? @relation(fields: [variationId], references: [id])
  vendor      Vendor            @relation(fields: [vendorId], references: [id])
}

model Withdrawal {
  id        String   @id @default(cuid())
  vendorId  String
  amount    Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
}

model Settings {
  id                  String  @id @default("global")
  exchangeRate        Float   @default(1.0)
  baseCurrency        String  @default("SDG")
  platformCommission  Float   @default(10.0)
  maintenanceMode     Boolean @default(false)
  maintenanceMessage  String  @default("هناك خطأ تقني يجري إصلاحه")
  codEnabled          Boolean @default(true)
  codExtraFee         Float   @default(2000)
  codCitiesOnly       String  @default("الخرطوم")
  bankTransferEnabled Boolean @default(true)
  bankName            String  @default("")
  bankAccountNumber   String  @default("")
  bankAccountName     String  @default("")
  contactEmail        String?
  contactPhone        String?
  facebookUrl         String?
  instagramUrl        String?
  logo                String?
  primaryColor        String  @default("#1089A4")
  secondaryColor      String  @default("#F29124")
  siteDescription     String  @default("أكبر منصة تسوق في السودان")
  siteTitle           String  @default("مرسال - تسوق بذكاء")
  whatsappNumber      String?
}

model SiteBanner {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  imageUrl  String
  link      String?
  type      String   @default("HOME_HERO")
  targetId  String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model DeliveryZone {
  id       String  @id @default(cuid())
  fromCity String
  toCity   String
  fee      Float
  isActive Boolean @default(true)
}

model ShippingProvider {
  id        String   @id @default(cuid())
  name      String
  apiKey    String
  baseUrl   String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DeliveryDriver {
  id          String   @id @default(cuid())
  name        String
  phone       String
  vehicleType String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  orders      Order[]
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  productId String
  userId    String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  discountType   String
  discountValue  Float
  minOrderAmount Float?    @default(0)
  maxDiscount    Float?    @default(0)
  expiryDate     DateTime?
  isActive       Boolean   @default(true)
  vendorId       String
  createdAt      DateTime  @default(now())
  vendor         Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}
